{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ordius",
  "version": "0.1.0",
  "identifier": "io.github.wintersta7e.ordius",
  "build": {
    "beforeDevCommand": "npm --prefix ./ui run dev",
    "beforeBuildCommand": "npm --prefix ./ui run build",
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Ordius",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool"
  }
}
